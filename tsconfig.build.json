{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    // Keep Jest/Node types out of the published declarations, but vite/client must stay:
    // it supplies the ambient *.module.css / *.css typings the components import.
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "**/*.stories.tsx"]
}
